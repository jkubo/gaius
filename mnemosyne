#!/usr/bin/env python3
"""mnemosyne - Memory file health and maintenance tool.

Usage:
  mnemosyne [--memory-dir DIR] <command> [args]

Options:
  --memory-dir DIR  Path to memory root
                    (env: MNEMOSYNE_MEMORY_DIR, default: ~/.gaius/memory)

Commands:
  health           Line counts, byte budget, and threshold status for all memory files.
                   Also lints MEMORY.md for index-line gloss accretion (Gap-32) and,
                   when over byte budget, points at the heaviest lines to compress.
  audit            Scan common.md for entries that belong in domain files
  split <file>     Propose a split plan for an oversized file (never auto-executes)
  prune <file>     Identify redundant or stale entries (never auto-deletes)
"""

import argparse
import os
import re
import sys
from pathlib import Path

# ── Configuration ────────────────────────────────────────────────────────────

def _default_memory_dir() -> Path:
    # Priority: env var > gaius config > ~/.gaius/memory
    if os.environ.get("MNEMOSYNE_MEMORY_DIR"):
        return Path(os.environ["MNEMOSYNE_MEMORY_DIR"])
    cfg = Path.home() / ".gaius" / "config.yaml"
    if cfg.exists():
        try:
            import yaml
            data = yaml.safe_load(cfg.read_text()) or {}
            p = data.get("mnemosyne", {}).get("memory_dir")
            if p:
                return Path(p).expanduser()
        except Exception:
            pass
    return Path.home() / ".gaius" / "memory"

DEFAULT_MEMORY_DIR = _default_memory_dir()

# Thresholds — (warn, error) line counts per file category.
# GREEN: below warn. YELLOW: warn ≤ lines < error. RED: lines ≥ error.
THRESHOLDS = {
    "MEMORY.md":  (180, 200),
    "common.md":  (80,  100),
    "domain":     (150, 200),   # applies to all domain/*.md
    "skills":     (300, 500),   # skills/*.md — longer than domain (no gotchas), shorter than other
    "other":      (400, 600),   # host-layer topic files (narrative/deep-ref, OK to be long)
}

# Domain keyword map — used by `audit` to flag common.md entries.
# key = domain file stem, value = keywords that signal domain-specific content.
# Loaded from ~/.gaius/config.yaml [mnemosyne.audit_keywords] if present;
# otherwise uses generic infra/ops defaults below.
def _load_domain_keywords() -> dict:
    # Respect GAIUS_CONFIG env var so tests can override with /dev/null
    cfg_env = os.environ.get("GAIUS_CONFIG")
    cfg = Path(cfg_env) if cfg_env else (Path.home() / ".gaius" / "config.yaml")
    if cfg.exists() and cfg != Path("/dev/null"):
        try:
            import yaml
            data = yaml.safe_load(cfg.read_text()) or {}
            kw = data.get("mnemosyne", {}).get("audit_keywords")
            if kw and isinstance(kw, dict):
                return kw
        except Exception:
            pass
    return {
        "storage":       ["drbd", "pvc", "storageclass", "nfs", "nvme", "sata", "blob",
                          "minio", "s3", "volume", "persistent"],
        "networking":    ["flannel", "cilium", "wireguard", "vxlan", "mtu", "cidr", "ingress",
                          "dns", "cors", "traefik", "http2", "loadbalancer", "tunnel"],
        "services":      ["helm", "oidc", "oauth2", "cert-manager", "ingress-controller"],
        "security":      ["vault", "secret", "tls", "cert", "rbac", "token",
                          "kubeconfig", "credential"],
        "gitops":        ["flux", "helmrelease", "kustomization", "gitops", "reconcile", "ci/cd"],
        "observability": ["alert", "metric", "dashboard", "prometheus", "grafana", "loki", "otel"],
    }

DOMAIN_KEYWORDS = _load_domain_keywords()

# ANSI colors
GREEN  = "\033[32m"
YELLOW = "\033[33m"
RED    = "\033[31m"
BOLD   = "\033[1m"
RESET  = "\033[0m"


def color_status(lines: int, warn: int, error: int) -> str:
    if lines >= error:
        return f"{RED}{BOLD}RED{RESET}"
    elif lines >= warn:
        return f"{YELLOW}YELLOW{RESET}"
    else:
        return f"{GREEN}GREEN{RESET}"


def count_lines(path: Path) -> int:
    try:
        return sum(1 for _ in path.open())
    except Exception:
        return -1


# A "- **bold bullet" merged mid-line (a missing newline between two facts).
# Requires a non-space char immediately before "- **" so legit " - **inline**"
# prose and internal hyphens in dates ("2026-06-08") don't false-positive.
JOINED_BULLET = re.compile(r"\S- \*\*")
LONG_LINE_CHARS = 2000   # a single line this long is accretion (changelog / mega-hook), not a fact


def scan_content_defects(path: Path):
    """Structural defects invisible to line/byte thresholds.

    Returns [(lineno, kind, detail)] where kind is 'joined-line' (corruption —
    a bullet got merged onto the previous line, hiding a fact) or 'long-line'
    (one runaway line; index/header accretion). Joined-line is blocking; long-line
    is advisory.
    """
    defects = []
    try:
        for i, raw in enumerate(path.open(), 1):
            line = raw.rstrip("\n")
            m = JOINED_BULLET.search(line)
            if m:
                start = max(0, m.start() - 22)
                defects.append((i, "joined-line", "…" + line[start:m.start() + 24].strip()))
            elif len(line) > LONG_LINE_CHARS:
                defects.append((i, "long-line", f"{len(line)} chars on one line"))
    except Exception:
        pass
    return defects


# ── MEMORY.md index-gloss accretion (Gap-32 structural cure) ──────────────────
# The byte budget catches the TOTAL but not WHERE, and the 2000-char runaway
# check never fires on index lines (they top out ~1300-1700 chars). So the
# `## Project Files` index mega-lines accrete gloss until the 16KB budget blows,
# and every surgeon then hand-hunts the fat lines. This lint catches the
# accretion EARLY by measuring *non-link gloss bytes* — it strips `[label](path)`
# link tokens and counts the remaining prose, so a vertical with many terse links
# is fine but one whose links carry paragraph glosses is flagged. Detail on an
# index line belongs in the linked project file; the index is navigation.
INDEX_GLOSS_WARN = 350         # non-link gloss bytes on one index line over this = accretion
PROJECT_FILES_HEADER = "## Project Files"
_LINK_TOKEN = re.compile(r"\[[^\]]*\]\([^)]*\)")


def scan_index_gloss(path: Path, threshold: int = INDEX_GLOSS_WARN):
    """Index lines under '## Project Files' carrying > `threshold` bytes of
    non-link gloss. Returns [(lineno, gloss_bytes, total_bytes, preview)]
    heaviest-first. Advisory only — never blocks (the index is navigation; the
    detail belongs in the linked file)."""
    fat = []
    in_section = False
    try:
        for i, raw in enumerate(path.open(), 1):
            line = raw.rstrip("\n")
            if line.startswith(PROJECT_FILES_HEADER):
                in_section = True
                continue
            if in_section and line.startswith("## "):
                break  # next H2 ends the index section
            if in_section and line.lstrip().startswith(("-", "*")):
                gloss = len(_LINK_TOKEN.sub("", line))
                if gloss > threshold:
                    fat.append((i, gloss, len(line), line.lstrip()[:50]))
    except Exception:
        pass
    fat.sort(key=lambda t: -t[1])
    return fat


def heaviest_lines(path: Path, n: int = 5):
    """The n longest lines in a file (targeting aid when over byte budget):
    [(lineno, length, preview)] heaviest-first."""
    rows = []
    try:
        for i, raw in enumerate(path.open(), 1):
            line = raw.rstrip("\n")
            rows.append((i, len(line), line.lstrip()[:50]))
    except Exception:
        return []
    rows.sort(key=lambda t: -t[1])
    return rows[:n]


# ── Commands ─────────────────────────────────────────────────────────────────

def scan_index_completeness(memory_dir: Path):
    """Every active feedback rule must be catalogued in feedback/INDEX.md, and no
    retired (.archive/) rule should still be listed. Catches the catalog-drift class
    that let 64 rules — incl HARD gates — go invisible in the always-injected
    awareness layer (cured 2026-07-03). Feedback-scoped: keys are deterministic
    (filename stem minus 'feedback_'), so this is zero-false-positive.
    Returns [(key, kind)] where kind is 'missing' | 'ghost'. WARN-mode (advisory).
    """
    fb = memory_dir / "feedback"
    idxp = fb / "INDEX.md"
    if not fb.is_dir() or not idxp.exists():
        return []
    idx = idxp.read_text(errors="ignore")
    findings, active_keys = [], set()
    for p in fb.glob("feedback_*.md"):
        key = p.stem[len("feedback_"):]
        active_keys.add(key)
        if not re.search(r"\b" + re.escape(key) + r"\b", idx):
            findings.append((key, "missing"))
    arch = fb / ".archive"
    if arch.is_dir():
        for p in arch.glob("feedback_*.md"):
            key = p.stem[len("feedback_"):]
            if key not in active_keys and re.search(r"\b" + re.escape(key) + r"\b", idx):
                findings.append((key, "ghost"))
    return findings


def cmd_health(memory_dir: Path, args: list):
    """Print line counts and health status for all memory files."""
    files = []

    # Named files in root
    for name in ["MEMORY.md", "common.md"]:
        p = memory_dir / name
        if p.exists():
            warn, error = THRESHOLDS[name]
            files.append((str(p.relative_to(memory_dir)), count_lines(p), warn, error))

    # Other root-level .md files (not MEMORY.md/common.md/RULES.md)
    skip_root = {"MEMORY.md", "common.md", "RULES.md"}
    for p in sorted(memory_dir.glob("*.md")):
        if p.name not in skip_root:
            warn, error = THRESHOLDS["other"]
            files.append((p.name, count_lines(p), warn, error))

    # Domain files
    domain_dir = memory_dir / "domain"
    if domain_dir.is_dir():
        for p in sorted(domain_dir.glob("*.md")):
            warn, error = THRESHOLDS["domain"]
            files.append((f"domain/{p.name}", count_lines(p), warn, error))

    # Skills files
    skills_dir = memory_dir / "skills"
    if skills_dir.is_dir():
        for p in sorted(skills_dir.glob("*.md")):
            warn, error = THRESHOLDS["skills"]
            files.append((f"skills/{p.name}", count_lines(p), warn, error))

    # Print table
    col_file  = max(len(r[0]) for r in files) + 2
    col_lines = 7
    print(f"\n{'File':<{col_file}} {'Lines':>{col_lines}}  Threshold   Status")
    print("─" * (col_file + col_lines + 22))
    for fname, lines, warn, error in files:
        status = color_status(lines, warn, error)
        thresh = f"warn={warn}/err={error}"
        print(f"{fname:<{col_file}} {lines:>{col_lines}}  {thresh:<14} {status}")

    print()

    # ── MEMORY.md byte budget (injection budget; a few long lines can blow it
    #    while staying under the line cap, so it is checked separately) ──
    BYTE_WARN, BYTE_ERR = 16 * 1024, 20 * 1024
    byte_red = byte_yellow = False
    _mem = memory_dir / "MEMORY.md"
    if _mem.exists():
        _sz = _mem.stat().st_size
        if _sz >= BYTE_ERR:
            _bs = f"{RED}{BOLD}RED{RESET}"; byte_red = True
        elif _sz >= BYTE_WARN:
            _bs = f"{YELLOW}YELLOW{RESET}"; byte_yellow = True
        else:
            _bs = f"{GREEN}GREEN{RESET}"
        print(f"{'File':<{col_file}} {'Size':>7}  Threshold              Status")
        print("─" * (col_file + 30))
        print(f"{'MEMORY.md':<{col_file}} {_sz / 1024:>6.1f}KB  warn=16.0KB/err=20.0KB {_bs}")
        print()

    # ── Content defects: structural corruption invisible to line/byte checks ──
    paths = []
    for name in ["MEMORY.md", "common.md"]:
        p = memory_dir / name
        if p.exists():
            paths.append(p)
    for p in sorted(memory_dir.glob("*.md")):
        if p.name not in skip_root:
            paths.append(p)
    for sub in ("domain", "skills"):
        d = memory_dir / sub
        if d.is_dir():
            paths.extend(sorted(d.glob("*.md")))
    joined, longish = [], []
    for p in paths:
        for lineno, kind, detail in scan_content_defects(p):
            rel = p.relative_to(memory_dir)
            (joined if kind == "joined-line" else longish).append((rel, lineno, detail))

    # Summary
    reds    = [r for r in files if r[1] >= r[3]]
    yellows = [r for r in files if r[2] <= r[1] < r[3]]
    mem_gloss = scan_index_gloss(_mem) if _mem.exists() else []
    idx_incomplete = scan_index_completeness(memory_dir)
    if reds:
        print(f"{RED}{BOLD}⚠  {len(reds)} file(s) over limit:{RESET} "
              + ", ".join(r[0] for r in reds))
    if joined:
        red = f"{RED}{BOLD}RED{RESET}"   # exact token the pre-commit hook greps to block
        print(f"{RED}{BOLD}⚠  {len(joined)} joined-line defect(s){RESET} [{red}] — "
              "a merged bullet hides a fact; fix the missing newline before commit:")
        for rel, lineno, detail in joined:
            print(f"   {rel}:{lineno}  {detail}")
    if yellows:
        print(f"{YELLOW}⚡  {len(yellows)} file(s) approaching limit:{RESET} "
              + ", ".join(r[0] for r in yellows))
    if longish:
        print(f"{YELLOW}⚡  {len(longish)} runaway line(s) >{LONG_LINE_CHARS} chars "
              f"(accretion — compress to a pointer):{RESET}")
        for rel, lineno, detail in longish:
            print(f"   {rel}:{lineno}  {detail}")
    if mem_gloss:
        print(f"{YELLOW}⚡  {len(mem_gloss)} MEMORY.md index line(s) >{INDEX_GLOSS_WARN}B "
              f"non-link gloss (Gap-32 accretion — move the detail to the linked file, "
              f"keep the index a terse hook):{RESET}")
        for lineno, gloss, total, preview in mem_gloss:
            print(f"   MEMORY.md:{lineno}  {gloss}B gloss / {total}B line  {preview}…")
    if idx_incomplete:
        miss = [k for k, knd in idx_incomplete if knd == "missing"]
        ghost = [k for k, knd in idx_incomplete if knd == "ghost"]
        print(f"{YELLOW}⚡  feedback/INDEX drift: {len(miss)} rule(s) unlisted, "
              f"{len(ghost)} retired-but-still-listed (awareness gap — reconcile INDEX):{RESET}")
        if miss:
            print(f"   missing: {', '.join(miss[:15])}{' …' if len(miss) > 15 else ''}")
        if ghost:
            print(f"   ghost:   {', '.join(ghost)}")
    if byte_yellow:
        print(f"{YELLOW}⚡  MEMORY.md over the 16KB injection-budget warn — compress.{RESET}")
    if byte_red:
        red = f"{RED}{BOLD}RED{RESET}"
        print(f"{RED}{BOLD}⚠  MEMORY.md over the 20KB error{RESET} [{red}] — compress before commit.")
    if (byte_yellow or byte_red) and _mem.exists():
        print(f"{YELLOW}   heaviest lines (target these first):{RESET}")
        for lineno, length, preview in heaviest_lines(_mem):
            print(f"     MEMORY.md:{lineno}  {length}B  {preview}…")
    if (not reds and not yellows and not joined and not longish
            and not byte_red and not byte_yellow and not mem_gloss
            and not idx_incomplete):
        print(f"{GREEN}✓  All files within threshold.{RESET}")
    print()


def cmd_audit(memory_dir: Path, args: list):
    """Scan common.md for entries that belong in domain files instead."""
    common = memory_dir / "common.md"
    if not common.exists():
        print(f"ERROR: {common} not found", file=sys.stderr)
        sys.exit(1)

    lines = common.read_text().splitlines()
    findings = []  # list of (line_num, line_text, suggested_domain)

    for i, line in enumerate(lines, 1):
        stripped = line.strip()
        # Only check bullet-point lines (agents write bullet facts)
        if not stripped.startswith("-") and not stripped.startswith("*"):
            continue
        lower = stripped.lower()
        matches = []
        for domain, keywords in DOMAIN_KEYWORDS.items():
            for kw in keywords:
                if kw.lower() in lower:
                    matches.append(domain)
                    break
        # Only flag if matched and the content seems too specific for common.md
        # (common.md is for cross-cutting hard rules; domain-specific gotchas belong elsewhere)
        if matches:
            # Skip if line is a universal hard rule (never, always, all agents)
            is_universal = any(w in lower for w in ["never", "always", "all agents", "hard rule"])
            if not is_universal:
                findings.append((i, stripped[:100], matches[0]))

    if not findings:
        print(f"{GREEN}✓  No domain-specific entries found in common.md.{RESET}")
        return

    print(f"\n{YELLOW}⚡  {len(findings)} entries in common.md may belong in domain files:{RESET}\n")
    by_domain: dict[str, list] = {}
    for lineno, text, domain in findings:
        by_domain.setdefault(domain, []).append((lineno, text))

    for domain in sorted(by_domain):
        print(f"  → {BOLD}domain/{domain}.md{RESET}")
        for lineno, text in by_domain[domain]:
            print(f"     line {lineno:3d}: {text[:90]}")
        print()

    print("These are suggestions only. Review before moving.\n")


def cmd_split(memory_dir: Path, args: list):
    """Propose a split plan for an oversized file. Never auto-executes."""
    if not args:
        print("Usage: mnemosyne split <file>", file=sys.stderr)
        sys.exit(1)

    target = Path(args[0])
    if not target.is_absolute():
        target = memory_dir / args[0]
    if not target.exists():
        print(f"ERROR: {target} not found", file=sys.stderr)
        sys.exit(1)

    lines = target.read_text().splitlines()
    total = len(lines)
    print(f"\n{BOLD}Split proposal for {target.name}{RESET} ({total} lines)\n")

    # Parse sections by H2 (##) headers
    sections = []  # list of (header_text, start_line, line_count)
    current_header = "(preamble)"
    current_start = 1
    current_lines = 0

    for i, line in enumerate(lines, 1):
        if line.startswith("## "):
            if current_lines > 0:
                sections.append((current_header, current_start, current_lines))
            current_header = line[3:].strip()
            current_start = i
            current_lines = 1
        else:
            current_lines += 1

    if current_lines > 0:
        sections.append((current_header, current_start, current_lines))

    # Print section breakdown
    col_h = max(len(s[0]) for s in sections) + 2
    print(f"  {'Section':<{col_h}} {'Lines':>6}  {'Start':>6}")
    print("  " + "─" * (col_h + 16))
    for header, start, count in sections:
        flag = f"  {YELLOW}←{RESET}" if count > 30 else ""
        print(f"  {header:<{col_h}} {count:>6}  {start:>6}{flag}")

    print()

    # Identify move candidates (sections > 30 lines that look like gotcha/troubleshooting content)
    TROUBLESHOOTING_MARKERS = [
        "gotcha", "issue", "fix", "debug", "troubleshoot", "problem", "error",
        "broken", "caveat", "warning", "boot", "race", "drift", "leak"
    ]
    TOPIC_FILE_MARKERS = {
        "storage":      ["storage", "drbd", "pvc", "s3", "volume"],
        "networking":   ["network", "flannel", "cilium", "dns", "tunnel", "ingress"],
        "observability":["observ", "metric", "alert", "grafana", "loki"],
        "services":     ["service", "oauth", "helm", "cert"],
    }

    candidates = []
    for header, start, count in sections:
        if count < 15:
            continue
        lower = header.lower()
        # Check if section looks like troubleshooting content
        if any(m in lower for m in TROUBLESHOOTING_MARKERS):
            candidates.append((header, start, count, "troubleshooting.md"))
            continue
        # Check topic file matches
        for topic, markers in TOPIC_FILE_MARKERS.items():
            if any(m in lower for m in markers):
                candidates.append((header, start, count, f"{topic}.md"))
                break

    if candidates:
        print(f"{YELLOW}Suggested moves (lines {total} → target <{int(total*0.6)}):{RESET}\n")
        saved = 0
        for header, start, count, dest in candidates:
            print(f"  Move '{header}' ({count} lines, starts at {start}) → {dest}")
            saved += count
        remaining = total - saved
        print(f"\n  After moves: ~{remaining} lines remaining in {target.name}")
        if remaining <= 180:
            print(f"  {GREEN}✓ Would bring file within threshold.{RESET}")
        else:
            print(f"  {YELLOW}⚡ Still over warn threshold — consider further consolidation.{RESET}")
    else:
        print(f"{YELLOW}No obvious split candidates found. Review sections manually.{RESET}")

    print(f"\n{BOLD}This is a proposal only.{RESET} Apply changes manually.\n")


def cmd_prune(memory_dir: Path, args: list):
    """Identify redundant or stale entries in a memory file. Never auto-deletes."""
    if not args:
        print("Usage: mnemosyne prune <file>", file=sys.stderr)
        sys.exit(1)

    target = Path(args[0])
    if not target.is_absolute():
        target = memory_dir / args[0]
    if not target.exists():
        print(f"ERROR: {target} not found", file=sys.stderr)
        sys.exit(1)

    lines = target.read_text().splitlines()
    total = len(lines)
    findings = []

    # Patterns that signal stale or speculative content
    STALE_PATTERNS = [
        (r"\bpending\b",               "pending implementation"),
        (r"\bnot yet (built|implemented|functional|wired)\b", "unbuilt feature"),
        (r"\bdeferred\b",              "deferred item"),
        (r"\bfuture\b",                "future/speculative"),
        (r"\bdesign intent\b",         "design intent (not reality)"),
        (r"\bTODO\b",                  "TODO marker"),
        (r"\bWIP\b",                   "work in progress"),
        (r"\btemporary\b",             "marked temporary"),
        (r"#\d{1,3}\b.*\bpending\b",   "open issue (pending)"),
        (r"\bfixed\b.*\b20\d\d-\d\d-\d\d\b", "dated fix (verify still relevant)"),
    ]

    # Duplicate detection — track H2 section headers
    seen_headers = {}
    current_section = None
    seen_bullet_keys = {}

    for i, line in enumerate(lines, 1):
        stripped = line.strip()

        # Track section headers for duplicate detection
        if line.startswith("## "):
            header = line[3:].strip()
            if header in seen_headers:
                findings.append((i, line.strip(), f"duplicate section header (first at line {seen_headers[header]})"))
            seen_headers[header] = i
            current_section = header
            continue

        # Check stale patterns
        lower = stripped.lower()
        for pattern, label in STALE_PATTERNS:
            if re.search(pattern, lower):
                findings.append((i, stripped[:100], label))
                break

        # Track bullet keys for rough duplicate detection (first 6 words as key)
        if stripped.startswith("-") or stripped.startswith("*"):
            words = lower.split()[:6]
            key = " ".join(words)
            if key in seen_bullet_keys and key not in {"- **", "- use", "- never", "- all"}:
                findings.append((i, stripped[:100],
                                  f"possible duplicate of line {seen_bullet_keys[key]}"))
            else:
                seen_bullet_keys[key] = i

    if not findings:
        print(f"\n{GREEN}✓  No obvious stale or redundant entries found in {target.name}.{RESET}\n")
        return

    print(f"\n{YELLOW}⚡  {len(findings)} candidate(s) for pruning in {target.name}:{RESET}\n")
    for lineno, text, reason in findings:
        print(f"  line {lineno:4d}: [{reason}]")
        print(f"           {text[:95]}")
        print()

    print(f"{BOLD}This is a proposal only.{RESET} Review each entry before removing.\n")


# ── Dispatch ─────────────────────────────────────────────────────────────────

COMMANDS = {
    "health": cmd_health,
    "audit":  cmd_audit,
    "split":  cmd_split,
    "prune":  cmd_prune,
}


def main():
    parser = argparse.ArgumentParser(
        description="Memory file health and maintenance",
        usage="mnemosyne [--memory-dir DIR] <command> [args]",
    )
    parser.add_argument("--memory-dir", type=str, default=None,
                        help="Override memory root directory (env: MNEMOSYNE_MEMORY_DIR)")
    parser.add_argument("command", choices=list(COMMANDS.keys()),
                        help="Command to run")
    parser.add_argument("args", nargs="*", help="Command arguments")

    parsed = parser.parse_args()

    # Resolve memory dir: flag > env > default
    memory_dir = DEFAULT_MEMORY_DIR
    if parsed.memory_dir:
        memory_dir = Path(parsed.memory_dir)
    elif os.environ.get("MNEMOSYNE_MEMORY_DIR"):
        memory_dir = Path(os.environ["MNEMOSYNE_MEMORY_DIR"])

    if not memory_dir.is_dir():
        print(f"ERROR: memory directory not found: {memory_dir}", file=sys.stderr)
        sys.exit(1)

    COMMANDS[parsed.command](memory_dir, parsed.args)


if __name__ == "__main__":
    main()
